{
  "compilerOptions": {
    "baseUrl": "./",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "target": "ES2017"
  },
  "include": [
    "shims-*.d.ts",
    "sandbox/**/*.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "vite.config.common.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.coverage.ts",
    "vitest.e2e.ts"
  ]
}
